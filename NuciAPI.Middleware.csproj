    <RootNamespace>NuciAPI.Middleware</RootNamespace>
    <Version>1.1.0</Version>
    <Description>NuciAPI.Middleware</Description>
    <Authors>Horațiu Mlendea</Authors>
    <Copyright>Copyright 2026 © Horațiu Mlendea</Copyright>
    <RepositoryUrl>https://github.com/hmlendea/nuciapi.middleware</RepositoryUrl>
    <PackageLicenseExpression>GPL-3.0-or-later</PackageLicenseExpression>
